# ─────────────────────────────────────────────
# LinkedIn Engagement Assistant — Backend Config
# Copy to .env and fill in required values
# ─────────────────────────────────────────────

# REQUIRED: Shared secret between extension and backend
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=your-secret-key-here

# LLM provider: openai | gemini | anthropic
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./lea.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lea

# CORS — comma-separated origins allowed to call the API
# Include your Chrome extension origin: chrome-extension://<your-extension-id>
ALLOWED_ORIGINS=["chrome-extension://","http://localhost:3000"]your-extension-id,http://localhost:3000

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# News API key (optional — for trend enrichment)
NEWS_API_KEY=

# Webhook signing secret (auto-generated if empty)
WEBHOOK_SIGNING_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
